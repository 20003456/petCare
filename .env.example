# Supabase project URL. Example: https://your-project-ref.supabase.co
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable key. This can be used by browser code.
SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase service role key. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Postgres connection for Next.js API routes / Netlify Functions.
# Recommended: fill both with the same Supabase Session Pool connection string.
DATABASE_URL=
SUPABASE_SESSION_POOL_URL=

# Optional fallback if you do not use DATABASE_URL / SUPABASE_SESSION_POOL_URL.
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=
PGPORT=5432

# Server-only DeepSeek API key for the AI pet consultation assistant.
# Never prefix this with NEXT_PUBLIC_.
DEEPSEEK_API_KEY=
